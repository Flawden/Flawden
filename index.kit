            <div class="Count">
                <div class="container">
                    <div class="Count__body">
                        <div class="Count__title">Расчет стоимости</div>
                            <form action="#" class="Count__form">
                                <div class="Count__label">Тип сайта</div>
                                <select size="1" id="Type" class="Count__select">
                                    <option disabled selected value="">Выберите пункт</option>
                                    <option value="5000 3">Лендинг</option>
                                    <option value="15000 10">Многостраничный</option>
                                </select>

                                <div class="Count__label">Дизайн</div>
                                <select size="1" id="Design" class="Count__select">
                                    <option disabled selected value="">Выберите пункт</option>
                                    <option value="0 0">От вас</option>
                                    <option value="5000 2">От нас</option>
                                </select>

                                <div class="Count__label">Адаптивность</div>
                                <select size="1" id="Adaptive" class="Count__select">
                                    <option disabled selected value="">Выберите пункт</option>
                                    <option value="2000 1">Отзывчивость</option>
                                    <option value="3000 2">Адаптивность</option>
                                    <option value="5000 3">Отзывчивый-адаптив</option>
                                </select>

                            </form>
                            <div class="Count__result">
                                <div class="Count__resultBody">

                                    <div class="Count__resultItem">
                                        <h3 class="Count__resultTitle">Сроки</h3>
                                        <h3 class="Count__resultNum" id="term">0</h3> 
                                    </div>

                                    <div class="Count__resultItem">
                                        <h3 class="Count__resultTitle">Стоимость</h3>
                                        <h3 class="Count__resultNum" id="num">0</h3> 
                                    </div>

                                </div>

                            </div>

                    </div>
                </div>
